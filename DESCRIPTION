Package: dynR
Title: Dynamic Functional Connectivity Analysis for Neuroimaging Research
Version: 0.1.0
Authors@R: c(
    person("Lucas", "França",
           email = "lucas.franca@northumbria.ac.uk",
           role = c("aut", "cre"),
           comment = c(ORCID = "0000-0003-0853-1319")),
    person("Dafnis", "Batallé",
